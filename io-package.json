{
	"common": {
		"name": "waterkotte",
		"version": "0.0.1",
		"news": {
			"0.0.1": {
				"en": "initial release",
				"de": "Erstveröffentlichung"
			}
		},
		"title": {
			"en": "Waterkotte",
			"de": "Waterkotte"
		},
		"desc": {
			"en": "heating system waterkotte",
			"de": "heating system waterkotte"
		},
		"authors": [
			"Pietri67 <torsten.voigt@nobibum.de>"
		],
		"keywords": [
			"heating",
			"waterkotte",
			"ioBroker"
		],
		"license": "MIT",
		"platform": "Javascript/Node.js",
		"icon": "waterkotte.png",
		"enabled": true,
		"loglevel": "info",
		"messagebox": true,
		"extIcon": "https://raw.githubusercontent.com/Pietri67/ioBroker.waterkotte/master/admin/waterkotte.png",
		"readme": "https://github.com/Pietri67/ioBroker.waterkotte/blob/master/README.md",
		"mode": "daemon",
		"type": "iot-systems",
		"compact": true,
		"connectionType": "local",
		"dataSource": "poll",
		"materialize": true,
		"dependencies": [
			{
				"js-controller": ">=2.0.0"
			}
		]
	},
	"native": {
		"usbport": "/dev/ttyUSB0",
		"baudrate": 9600,
		"timeout": 30000,
		"repeat1": 1,
		"repeat2": 5,
		"repeat3": 5
	},
	"objects": [],
	"instanceObjects": [
		{
		  "_id": "info",
		  "type": "channel",
		  "common": {
			"name": "Information"
		  },
		  "native": {}
		},
		{
		  "_id": "info.connection",
		  "type": "state",
		  "common": {
			"role": "indicator.connected",
			"name": "If connected to Waterkotte",
			"type": "boolean",
			"read": true,
			"write": false,
			"def": false
		  },
		  "native": {}
		},
		{
			"_id": "info.lastmsg",
			"type": "state",
			"common": {
			  "role": "text",
			  "name": "last received Waterkotte message",
			  "type": "string",
			  "read": true,
			  "write": false,
			  "def": ""
			},
			"native": {}
		  }

	]	
}